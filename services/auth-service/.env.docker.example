NODE_ENV=development
PORT=8080
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/vietsage_auth?schema=public"
JWT_ACCESS_SECRET="replace-with-local-docker-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-local-docker-refresh-secret-at-least-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
JWT_ISSUER="vietsage-auth"
JWT_AUDIENCE="vietsage-web"
AUTH_SESSION_IDLE_TTL="30d"
AUTH_SESSION_ABSOLUTE_TTL="90d"
AUTH_REFRESH_IDEMPOTENCY_TTL_SECONDS=300
AUTH_IDEMPOTENCY_ENCRYPTION_KEY="replace-with-a-separate-encryption-key-at-least-32-chars"
# Set an ISO timestamp to close the legacy JWT refresh migration window.
AUTH_LEGACY_REFRESH_ACCEPT_UNTIL=
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
SWAGGER_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_TTL_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_LIMIT=10
AUTH_REFRESH_RATE_LIMIT_TTL_SECONDS=60
AUTH_REFRESH_RATE_LIMIT_LIMIT=30

AUTH_ADMIN_NAME="VietSage Admin"
AUTH_ADMIN_EMAIL="admin@vietsage.local"
AUTH_ADMIN_PASSWORD="ChangeMe123!"

AUTHZ_ROUTE_SYNC_ENABLED=true
AUTHZ_STRICT_MODE=false
AUTHZ_ENFORCEMENT_ENABLED=false

# Keep false for normal Docker dev startup. Run migrations manually after reviewing failures.
PRISMA_MIGRATE_ON_START=false

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_CATEGORY_RANGE=
GOOGLE_SERVICE_ITEM_RANGE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
