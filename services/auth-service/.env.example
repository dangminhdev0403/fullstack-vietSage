NODE_ENV=development
PORT=8080
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/vietsage_auth?schema=public"
JWT_ACCESS_SECRET="replace-with-local-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-local-refresh-secret-at-least-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
SWAGGER_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_TTL_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_LIMIT=10
AUTH_REFRESH_RATE_LIMIT_TTL_SECONDS=60
AUTH_REFRESH_RATE_LIMIT_LIMIT=30

# Optional bootstrap admin (created if missing, existing user is preserved)
AUTH_ADMIN_NAME="VietSage Admin"
AUTH_ADMIN_EMAIL="admin@vietsage.local"
AUTH_ADMIN_PASSWORD="ChangeMe123!"

AUTHZ_ROUTE_SYNC_ENABLED=true
AUTHZ_STRICT_MODE=false
AUTHZ_ENFORCEMENT_ENABLED=false

# Google Sheet config
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_CATEGORY_RANGE=
GOOGLE_SERVICE_ITEM_RANGE=
