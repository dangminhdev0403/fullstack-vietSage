{
  "name": "@dangminhdev/query-resource",
  "version": "0.1.0",
  "description": "Transport-agnostic, capability-driven resource factory for TanStack Query v5.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/rewrite-esm-imports.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.type-tests.json --noEmit",
    "typecheck:consumer": "tsc -p tsconfig.consumer.json --noEmit",
    "test": "node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
